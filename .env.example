# Firecrawl API Key（获取地址：https://firecrawl.dev）
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Anthropic API Key（获取地址：https://console.anthropic.com）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Pexels API Key（可选；优先调用 Pexels 视频接口，无视频时降级为图片+Ken Burns；未配置时使用渐变色兜底）
# 获取地址：https://www.pexels.com/api/（同一 Key 同时支持图片和视频接口）
PEXELS_API_KEY=your_pexels_api_key_here
